# Copy to .env and replace every <...> placeholder. Never commit .env.
ENVIRONMENT=development
AUTH_MODE=local
API_HOST=127.0.0.1
API_PUBLIC_URL=http://localhost:8001/v1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:1420,http://127.0.0.1:1420,tauri://localhost,http://tauri.localhost

POSTGRES_DB=fastlearner
POSTGRES_USER=fastlearner
POSTGRES_PASSWORD=<set-local-postgres-password>
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://fastlearner:<set-local-postgres-password>@localhost:5432/fastlearner

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<set-local-neo4j-password>

AI_PROVIDER=baseten
AI_MODEL=openai/gpt-oss-120b
AI_API_KEY=<set-server-side-api-key>
EMBEDDING_MODEL=<set-server-side-embedding-model>
AI_BASE_URL=https://inference.baseten.co/v1
# Optional speech models (leave unset to disable speech capabilities).
AI_TRANSCRIPTION_MODEL=
AI_SPEECH_MODEL=
AI_REQUEST_TIMEOUT_SECONDS=30
# Optional ElevenLabs text-to-speech. Key stays server-side.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
APP_ENCRYPTION_KEY=<set-server-side-encryption-key>
SESSION_SIGNING_SECRET=<set-server-side-signing-secret>

# This is the only frontend-exposed setting; never add credentials under VITE_*.
VITE_API_URL=http://localhost:8001/v1
